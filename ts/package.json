{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @actuallab/core -w @actuallab/rpc -w @actuallab/fusion -w @actuallab/fusion-rpc -w @actuallab/fusion-react",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -b packages/core/tsconfig.json packages/rpc/tsconfig.json packages/fusion/tsconfig.json packages/fusion-rpc/tsconfig.json packages/fusion-react/tsconfig.json",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "hash-wasm": "^4.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.0",
    "ws": "^8.16.0"
  },
  "prettier": {
    "arrowParens": "avoid",
    "tabWidth": 4,
    "parser": "typescript",
    "singleQuote": true,
    "trailingComma": "es5",
    "useTabs": false
  }
}
