{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/ packages/*/tests/",
    "typecheck": "tsc -b packages/*/tsconfig.json",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsup": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.0",
    "ws": "^8.16.0"
  },
  "prettier": {
    "arrowParens": "avoid",
    "tabWidth": 4,
    "parser": "typescript",
    "singleQuote": true,
    "trailingComma": "es5",
    "useTabs": false
  }
}
